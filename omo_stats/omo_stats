parser = argparse.ArgumentParser(prog="omo_stats", description="OpenCode usage statistics")
parser.add_argument("--today", action="store_true", help="Show today's sessions only")
parser.add_argument("--session", metavar="ID", help="Show detail for a specific session ID")


def main():
    args = parser.parse_args()
    if not os.path.exists(DB_PATH):
        print(f"Database not found: {DB_PATH}", file=sys.stderr)
        sys.exit(1)
    if args.session:
